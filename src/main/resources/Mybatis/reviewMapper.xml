<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.shinhan.memento.dao.ReviewDAO">

	<resultMap id="reviewSummaryMap"
		type="com.shinhan.memento.dto.ReviewSummaryDTO">
		<result property="mentoId" column="mento_id" />
		<result property="avgScore" column="avgScore" />
		<result property="reviewCount" column="reviewCount" />
	</resultMap>

	<select id="getMentoReviewSummary"
	 parameterType="int"
	 resultType="com.shinhan.memento.dto.ReviewSummaryDTO">
		SELECT
		mento_id mentoId,
		ROUND(AVG(score), 1) AS avgScore,
		COUNT(*) AS reviewCount
		FROM
		review
		WHERE
		mento_id = #{mentoId}
		AND status = 'ACTIVE'
		GROUP BY
		mento_id
	</select>

</mapper>
